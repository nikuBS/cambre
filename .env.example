# JSONbin.io 설정 (GitHub Pages 실시간 동기화용)
# .env.local 파일로 복사하여 사용하세요 (.env.local은 git에 커밋되지 않음)
#
# 설정 방법:
# 1. https://jsonbin.io 에서 무료 계정 생성
# 2. API Keys 메뉴에서 X-Access-Key 복사
# 3. Bins → Create Bin → 초기 데이터 저장 → Bin ID 복사
#
# GitHub Pages 배포 시:
# → 레포 Settings → Secrets and variables → Actions → New repository secret
# → VITE_JSONBIN_KEY, VITE_JSONBIN_ID 각각 추가

VITE_JSONBIN_KEY=your_x_access_key_here
VITE_JSONBIN_ID=your_bin_id_here
